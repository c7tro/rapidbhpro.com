<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>هدية حب لأمي ❤️</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Amiri&display=swap');

        body {
            margin: 0;
            padding: 0;
            font-family: 'Cairo', sans-serif;
            background: linear-gradient(135deg, #ffe4e1, #ffb6c1, #ffc0cb);
            color: #333;
            text-align: center;
            overflow-x: hidden;
        }

        .container {
            max-width: 850px;
            margin: 0 auto;
            padding: 20px;
        }

        h1 {
            font-family: 'Amiri', serif;
            font-size: 3.5rem;
            color: #d63384;
            text-shadow: 3px 3px 10px rgba(0,0,0,0.1);
            margin: 20px 0;
        }

        .game-container {
            margin: 40px auto;
            position: relative;
            width: 300px;
            height: 300px;
        }

        #bigHeart {
            font-size: 180px;
            cursor: pointer;
            transition: transform 0.2s;
            user-select: none;
        }

        #bigHeart:active {
            transform: scale(1.35);
        }

        .score {
            font-size: 2.2rem;
            color: #d63384;
            margin: 20px 0;
            font-weight: 600;
        }

        .message {
            display: none;
            background: rgba(255,255,255,0.95);
            padding: 40px 30px;
            border-radius: 25px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
            margin: 30px auto;
            max-width: 750px;
            line-height: 1.9;
        }

        .heart-particle {
            position: absolute;
            font-size: 35px;
            pointer-events: none;
            animation: flyHeart 1.8s forwards;
            z-index: 10;
        }

        @keyframes flyHeart {
            0% { opacity: 1; transform: translate(0, 0) scale(1); }
            100% { opacity: 0; transform: translate(var(--x), var(--y)) scale(0.4); }
        }

        button {
            margin: 15px 8px;
            padding: 14px 32px;
            font-size: 1.2rem;
            background: #d63384;
            color: white;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 6px 20px rgba(214, 51, 132, 0.4);
        }

        button:hover {
            background: #c0266e;
        }

        /* صندوق التعليقات */
        .comments-section {
            margin-top: 40px;
            background: white;
            padding: 25px;
            border-radius: 20px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

        .comment-box {
            width: 100%;
            height: 80px;
            padding: 12px;
            border: 2px solid #ffb6c1;
            border-radius: 12px;
            font-size: 1.1rem;
            margin-bottom: 10px;
            resize: vertical;
        }

        .comments-list {
            max-height: 300px;
            overflow-y: auto;
            text-align: right;
            margin-top: 15px;
        }

        .comment {
            background: #fff0f5;
            padding: 12px 18px;
            margin: 10px 0;
            border-radius: 15px;
            text-align: right;
            border-right: 5px solid #d63384;
        }

        .comment-date {
            font-size: 0.85rem;
            color: #888;
            margin-top: 5px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>لأجمل أم في الدنيا ❤️</h1>
        
        <!-- شاشة اللعبة -->
        <div id="gameScreen">
            <p style="font-size: 1.5rem; margin: 15px 0;">اضغط على القلب الكبير واجمع نقاط الحب يا يما ❤️</p>
            
            <div class="game-container">
                <div id="bigHeart">❤️</div>
            </div>
            
            <div class="score">
                نقاط الحب: <span id="score">0</span> / 20
            </div>
            
            <button onclick="resetGame()">ابدأ من جديد</button>
        </div>

        <!-- الرسالة النهائية -->
        <div id="finalMessage" class="message">
            <h2 style="color: #d63384;">مبروك يا يما! 🎉</h2>
            
            <p style="font-size: 1.65rem; color: #6f42c1;">
                كيف حالك أمي الغالية؟<br><br>
                هذا الموقع سويته عشانك ❤️<br>
                ايش رأيك فيه يما؟<br><br>
                مشتاقلك يما وإن شاء الله برجع على الأردن بأسرع وقت<br><br>
                من ابنك قاسم<br>
                وسلمي على رحمة ورغد 💕
            </p>

            <!-- صندوق التعليقات -->
            <div class="comments-section">
                <h3 style="color: #d63384;">اتركي تعليقك يا يما ❤️</h3>
                <textarea id="commentInput" class="comment-box" placeholder="اكتبي رسالتك هنا..."></textarea>
                <button onclick="addComment()">إرسال التعليق</button>

                <div class="comments-list" id="commentsList">
                    <!-- التعليقات ستظهر هنا -->
                </div>
            </div>

            <button onclick="restartAll()" style="margin-top: 30px;">العب مرة أخرى</button>
        </div>
    </div>

    <script>
        let score = 0;
        const targetScore = 20;

        const bigHeart = document.getElementById('bigHeart');
        const scoreElement = document.getElementById('score');
        const gameScreen = document.getElementById('gameScreen');
        const finalMessage = document.getElementById('finalMessage');
        const commentsList = document.getElementById('commentsList');

        // تحميل التعليقات المحفوظة
        function loadComments() {
            const savedComments = JSON.parse(localStorage.getItem('mamaComments') || '[]');
            commentsList.innerHTML = '';
            
            savedComments.forEach(comment => {
                addCommentToDOM(comment.text, comment.date);
            });
        }

        function addCommentToDOM(text, date) {
            const commentDiv = document.createElement('div');
            commentDiv.className = 'comment';
            commentDiv.innerHTML = `
                <p>${text}</p>
                <div class="comment-date">${date}</div>
            `;
            commentsList.prepend(commentDiv); // أحدث تعليق في الأعلى
        }

        function addComment() {
            const input = document.getElementById('commentInput');
            const text = input.value.trim();
            
            if (text === '') return;

            const now = new Date();
            const dateStr = now.toLocaleDateString('ar-EG') + ' ' + now.toLocaleTimeString('ar-EG', {hour:'2-digit', minute:'2-digit'});

            // إضافة التعليق في الصفحة
            addCommentToDOM(text, dateStr);

            // حفظ التعليقات في localStorage
            let savedComments = JSON.parse(localStorage.getItem('mamaComments') || '[]');
            savedComments.unshift({ text: text, date: dateStr });
            localStorage.setItem('mamaComments', JSON.stringify(savedComments));

            // تنظيف حقل الكتابة
            input.value = '';
            
            // تأثير جميل
            createHeartParticle(window.innerWidth/2, window.innerHeight/2);
        }

        function createHeartParticle(x, y) {
            const heart = document.createElement('div');
            heart.classList.add('heart-particle');
            heart.textContent = ['❤️','💖','💗','💓','💕'][Math.floor(Math.random()*5)];
            
            heart.style.left = x + 'px';
            heart.style.top = y + 'px';
            
            const xMove = (Math.random() - 0.5) * 220;
            const yMove = - (120 + Math.random() * 180);
            heart.style.setProperty('--x', xMove + 'px');
            heart.style.setProperty('--y', yMove + 'px');
            
            document.body.appendChild(heart);
            
            setTimeout(() => heart.remove(), 2200);
        }

        bigHeart.addEventListener('click', function(e) {
            score++;
            scoreElement.textContent = score;

            const rect = bigHeart.getBoundingClientRect();
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;

            for (let i = 0; i < 6; i++) {
                createHeartParticle(centerX + (Math.random()*60 - 30), centerY);
            }

            if (score >= targetScore) {
                setTimeout(() => {
                    gameScreen.style.display = 'none';
                    finalMessage.style.display = 'block';
                    
                    // احتفال كبير
                    for (let i = 0; i < 40; i++) {
                        setTimeout(() => {
                            createHeartParticle(
                                Math.random() * window.innerWidth,
                                Math.random() * window.innerHeight * 0.7
                            );
                        }, i * 40);
                    }
                }, 400);
            }
        });

        function resetGame() {
            score = 0;
            scoreElement.textContent = '0';
        }

        function restartAll() {
            score = 0;
            scoreElement.textContent = '0';
            gameScreen.style.display = 'block';
            finalMessage.style.display = 'none';
        }

        // بداية الموقع
        window.onload = function() {
            loadComments();
            
            // قلوب ترحيبية
            for (let i = 0; i < 10; i++) {
                setTimeout(() => {
                    createHeartParticle(
                        Math.random() * window.innerWidth,
                        Math.random() * 250 + 100
                    );
                }, i * 150);
            }
        };
    </script>
</body>
</html>
